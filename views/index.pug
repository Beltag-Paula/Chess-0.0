doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel="stylesheet", href="/public/styles.css")
        title Chess Arena - Menu
    body
        div.menu-layout
            header.menu-header
                h1 ♞ Chess Arena ♞
                button#theme-toggle.btn.btn-small Change Theme

            main.menu-grid
                section.menu-card
                    h2 Vs Stockfish
                    p Challenge the engine locally. Adjust strength seamlessly mid-game.
                    div.menu-actions
                        a(href="/gameBot/white").btn Play White
                        a(href="/gameBot/black").btn.btn-dark Play Black

                section.menu-card
                    h2 Vs Human
                    p Jump into a lobby arena to test your skills against players online.
                    div.menu-actions
                        a(href="/gamePlayer/white").btn Play White
                        a(href="/gamePlayer/black").btn.btn-dark Play Black

        include buttonThemeChange.pug
